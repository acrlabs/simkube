#!/usr/bin/env bash

set -euo pipefail

suffix=""
sha="$(git rev-parse --short HEAD)"

if [[ -n "$(git status --porcelain --untracked-files=no)" ]]; then
    suffix="-$(uuidgen)"
fi

while IFS= read -r tag; do
    if [[ "$tag" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        printf "%s%s" "$tag" "$suffix"
        exit 0
    fi
done < <(git tag --points-at "$sha")

printf "%s%s" "$sha" "$suffix"
